PORT=3333
NODE_ENV=development

# Preferencial em produção (Neon/Render)
DATABASE_URL=

# Alternativa local (Docker/Postgres)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=rotas_ml
DB_USER=postgres
DB_PASS=postgres

JWT_SECRET=troque-por-um-segredo-forte-com-32-caracteres-ou-mais
JWT_EXPIRES_IN=1d

# Separe múltiplas origens com vírgula
CORS_ORIGIN=http://localhost:5173,https://seu-front.vercel.app

# Pode ser um JSON completo em linha ou base64
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opcional: restringe tokens ao projeto do Firebase
FIREBASE_PROJECT_ID=
